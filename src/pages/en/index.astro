---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout lang="en" title="ZJUAA NC North Carolina HQ Hub" description="Connecting and serving Zhejiang University alumni in North Carolina (including RTP and surrounding areas), promoting collaboration and community development." path="/">
  <div class="max-w-4xl mx-auto px-6 space-y-12">
    <!-- Hero -->
    <header class="text-center py-10 space-y-4">
      <div class="inline-flex items-center gap-x-2 bg-blue-950/40 text-blue-400 px-4 py-1.5 rounded-full text-xs font-semibold border border-blue-900/30">
        <span class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-ping"></span>
        <span>ZJUAA NC Liaison Hub</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-slate-200 leading-tight mt-2">
        ZJUAA NC<br><span class="ai-gradient">North Carolina HQ Hub</span>
      </h1>
      <p class="max-w-2xl mx-auto text-slate-400 text-base md:text-lg leading-relaxed">
        Connecting and serving Zhejiang University alumni in North Carolina (including RTP and surrounding areas), promoting collaboration, life mutual support, and community development.
      </p>
    </header>

    <!-- Hero Image Banner -->
    <div class="relative w-full h-48 md:h-64 rounded-3xl overflow-hidden border border-slate-900 shadow-2xl bg-slate-900 flex items-center justify-center group">
      <img src="/images/hero.jpg" alt="Hero Banner" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.015]" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950/40 to-transparent"></div>
    </div>

    <!-- Local Contact Section -->
    <section class="bg-slate-900/30 border border-slate-900 rounded-3xl p-6 md:p-8 space-y-4 shadow-xl">
      <h2 class="text-xl font-bold text-slate-200 flex items-center gap-x-2">
        <i class="fa-solid fa-location-dot text-blue-500"></i>
        <span>Local Liaison Representatives</span>
      </h2>
      
      <div class="grid md:grid-cols-2 gap-4">
        <!-- Contact 1 -->
        <div class="bg-blue-950/20 border border-blue-900/20 p-5 rounded-2xl flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-blue-600/10 text-blue-400 border border-blue-500/20 flex items-center justify-center font-bold text-lg shrink-0">
            NC
          </div>
          <div>
            <div class="text-base font-bold text-slate-200 leading-snug">Xiangwu Zhang (Vice Director)</div>
            <div class="text-xs text-slate-500 mt-1">Area of Responsibility: NC RTP Region & Colleges</div>
            <div class="text-xs text-blue-400 mt-2 flex items-center gap-x-1.5 justify-start">
              <i class="fa-regular fa-envelope"></i>
              <a href="mailto:nc@zjuaanc.org" class="hover:underline">nc@zjuaanc.org</a>
            </div>
          </div>
        </div>

        <!-- Contact 2 -->
        <div class="bg-blue-950/20 border border-blue-900/20 p-5 rounded-2xl flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-blue-600/10 text-blue-400 border border-blue-500/20 flex items-center justify-center font-bold text-lg shrink-0">
            NC
          </div>
          <div>
            <div class="text-base font-bold text-slate-200 leading-snug">Naiquan Zheng (Vice Director)</div>
            <div class="text-xs text-slate-500 mt-1">Area of Responsibility: NC Non-RTP Region & Financial Orgs</div>
            <div class="text-xs text-blue-400 mt-2 flex items-center gap-x-1.5 justify-start">
              <i class="fa-regular fa-envelope"></i>
              <a href="mailto:hq@zjuaanc.org" class="hover:underline">hq@zjuaanc.org</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Global Liaison Directory -->
    <section class="space-y-6">
      <h2 class="text-xl font-bold text-slate-200 flex items-center gap-x-2 border-b border-slate-900 pb-3">
        <i class="fa-solid fa-address-book text-blue-500"></i>
        <span>HQ Liaison Department Structure</span>
      </h2>
      <p class="text-xs text-slate-400 leading-relaxed">
        Liaison Department Director and Vice Directors for regions/industries:
      </p>
      
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
          <div class="font-bold text-slate-200 text-sm">Xiao Qi <span class="text-xs text-slate-500 font-normal">(Director)</span></div>
          <div class="text-xs text-slate-400 mt-1">Area: Washington State & Overseas</div>
        </div>
        <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
          <div class="font-bold text-slate-200 text-sm">Xiangwu Zhang <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
          <div class="text-xs text-slate-400 mt-1">Area: NC RTP Region & Colleges</div>
        </div>
        <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
          <div class="font-bold text-slate-200 text-sm">Naiquan Zheng <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
          <div class="text-xs text-slate-400 mt-1">Area: NC Non-RTP Region & Financial Orgs</div>
        </div>
        <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
          <div class="font-bold text-slate-200 text-sm">Gang Xu <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
          <div class="text-xs text-slate-400 mt-1">Area: Mainland China Sister Alumni Associations</div>
        </div>
        <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
          <div class="font-bold text-slate-200 text-sm">Qin Huang <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
          <div class="text-xs text-slate-400 mt-1">Area: Texas & Research Institutions</div>
        </div>
        <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
          <div class="font-bold text-slate-200 text-sm">Zhangxin Shen <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
          <div class="text-xs text-slate-400 mt-1">Area: Washington D.C. & Government Orgs</div>
        </div>
        <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
          <div class="font-bold text-slate-200 text-sm">Lei Qi <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
          <div class="text-xs text-slate-400 mt-1">Area: Mainland China & Alma Mater Relations</div>
        </div>
        <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
          <div class="font-bold text-slate-200 text-sm">Mingxu Huo <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
          <div class="text-xs text-slate-400 mt-1">Area: California, Tennessee, & Sister Organizations</div>
        </div>
        <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
          <div class="font-bold text-slate-200 text-sm">Wenbo Zhang <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
          <div class="text-xs text-slate-400 mt-1">Area: Florida & Chinese Schools / Local Organizations</div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
